{
  "name": "backend-easy-setup",
  "version": "1.0.0",
  "type": "module",
  "description": "CLI scaffold for creating an Express TypeScript backend with one npx command.",
  "license": "ISC",
  "author": "Nayan",
  "keywords": [
    "express",
    "typescript",
    "backend",
    "scaffold",
    "cli"
  ],
  "bin": "dist/cli.js",
  "files": [
    "dist",
    "template",
    "README.md"
  ],
  "engines": {
    "node": ">=18.17"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "npm run lint && tsc",
    "lint": "eslint src",
    "pack:check": "npm pack --dry-run",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.0.1",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3"
  }
}
